# GBrain Railway environment variables
# Copy to Railway service variables

# Neon Postgres connection string
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Jina AI embeddings (OpenAI-compatible endpoint)
OPENAI_BASE_URL=https://api.jina.ai/v1
OPENAI_API_KEY=jina_xxxxxxxxxxxxxxxxxxxxxxxx

# Embedding model config (matches Jina defaults)
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIMENSIONS=1024

# Force Postgres engine (not PGLite)
ENGINE=postgres
